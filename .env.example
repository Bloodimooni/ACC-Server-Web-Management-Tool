# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_real_secret

# Path to the ACC server directory (contains accServer.exe and cfg/)
SERVER_DIR=C:\ACCServer\server

# Dashboard listen address
HOST=0.0.0.0
PORT=8080

# Set to true if behind a TLS reverse proxy
HTTPS_ENABLED=false

# Local users file (bcrypt hashes)
USERS_FILE=users.json

# OIDC / Authentik — leave OIDC_ENABLED=false to hide the SSO button
OIDC_ENABLED=false
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=https://auth.example.com/application/o/acc-dashboard/.well-known/openid-configuration
OIDC_REDIRECT_URI=http://localhost:8080/auth/oidc/callback
